{
  "expo": {
    "name": "Limitless Solution",
    "slug": "Limitless-Solution",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logicon.png",
    "scheme": "limitlesssolution",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/appIco_foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shukumar.LimitlessSolution"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/appIco_foreground.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}